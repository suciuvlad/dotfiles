[user]
  name = Vlad Suciu
  email = suciu.vlad@gmail.com
  signingkey = ~/.ssh/id_ed25519.pub
[alias]
  # status / branch
  s = status --short
  st = status --short
  br = branch
  ba = branch -a
  # commit
  ci = commit
  c = commit -m
  ca = commit -a -m
  cad = commit -a --amend
  # checkout / reset
  co = checkout
  coall = checkout -- .
  re = reset
  # add
  ap = add -p
  # remote / push / pull
  r = remote
  p = push origin HEAD
  pu = pull origin
  # diff / log
  d = diff
  hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
  lg = log --oneline --decorate --all --graph
  glog = log --graph --topo-order --pretty='%w(100,0,6)%C(yellow)%h%C(bold)%C(black)%d %C(cyan)%ar %C(green)%an%n%C(bold)%C(white)%s %N' --abbrev-commit
  # plumbing
  type = cat-file -t
  dump = cat-file -p
[core]
  excludesfile = ~/.gitignore
  editor = nvim
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  light = false
  side-by-side = true
  line-numbers = true
[diff]
  colorMoved = default
  algorithm = histogram
[merge]
  conflictstyle = zdiff3
[rerere]
  enabled = true
[color]
  ui = true
[commit]
  template = ~/.gitmessage
  verbose = true
  gpgsign = true
[tag]
  gpgsign = true
[gpg]
  format = ssh
[gpg "ssh"]
  allowedSignersFile = ~/.ssh/allowed_signers
[push]
  default = simple
  autoSetupRemote = true
[pull]
  rebase = true
[fetch]
  prune = true
  pruneTags = true
[rebase]
  autoStash = true
  autoSquash = true
[branch]
  autosetuprebase = always
  sort = -committerdate
[init]
  defaultBranch = main
[help]
  autocorrect = prompt
[column]
  ui = auto
[url "git@github.com:"]
	insteadOf = https://github.com/

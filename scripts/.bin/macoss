#!/usr/bin/env bash
# Entry point — delegates to the Makefile next to this file.
# Run `macoss` to install everything, or `macoss <target>` for one step
# (e.g. `macoss defaults`, `macoss zsh`). Run `macoss help` for the list.
set -euo pipefail
SCRIPTS_DIR="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
exec make -C "$SCRIPTS_DIR" "${@:-all}"
